---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav>
    <h3 class="text-[10px] font-bold tracking-[0.2em] uppercase text-muted mb-4">On this page</h3>
    <ul class="space-y-2.5">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-[13px] leading-snug text-surface-600 hover:text-ink transition-colors',
              heading.depth === 3 && 'pl-4',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
