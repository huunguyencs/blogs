---
import { slugify } from '../../utils/slugify';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <a
      href={`/tag/${slugify(tag)}`}
      class="inline-block px-3 py-1.5 rounded-lg text-xs font-medium bg-surface-100 text-muted hover:bg-surface-200 hover:text-ink transition-colors"
    >
      #{tag}
    </a>
  ))}
</div>
