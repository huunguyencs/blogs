---
import { slugify } from '../../utils/slugify';
import { formatDate } from '../../utils/posts';
import { getReadingTime } from '../../utils/readingTime';
import { withBase } from '../../utils/url';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  image?: { src: string; alt: string };
  slug: string;
  rawContent: string;
}

const { title, description, date, category, image, slug, rawContent } = Astro.props;
const readingTime = getReadingTime(rawContent);
const href = withBase(`/blog/${slug}`);
---

<a href={href} class="group block relative isolate overflow-hidden rounded-3xl bg-surface-900">
  <!-- Gradient base (always visible) -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface-800 via-surface-900 to-ink" />

  <!-- Image layer -->
  {image && (
    <img
      src={image.src}
      alt={image.alt}
      class="absolute inset-0 w-full h-full object-cover opacity-60 transition-all duration-700 group-hover:scale-105 group-hover:opacity-50"
      loading="eager"
      onerror="this.style.display='none'"
    />
  )}

  <!-- Dark vignette overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10" />
  <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent" />

  <!-- Content -->
  <div class="relative z-10 flex flex-col justify-end h-full min-h-[420px] lg:min-h-[520px] p-8 lg:p-12">
    <div class="max-w-2xl">
      <!-- Category pill -->
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-bold tracking-widest uppercase bg-white/15 text-white/90 backdrop-blur-sm border border-white/10">
          {category}
        </span>
        <span class="text-[11px] font-medium text-white/50 tracking-wide uppercase">{readingTime}</span>
      </div>

      <!-- Title -->
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl xl:text-[3.5rem] text-white leading-[1.1] tracking-tight group-hover:text-white/90 transition-colors">
        {title}
      </h2>

      <!-- Description -->
      <p class="mt-4 text-base lg:text-lg text-white/65 leading-relaxed line-clamp-2 max-w-xl">
        {description}
      </p>

      <!-- Meta -->
      <div class="mt-6 flex items-center gap-4">
        <time datetime={date.toISOString()} class="text-[13px] text-white/40">{formatDate(date)}</time>
        <span class="inline-flex items-center gap-1.5 text-[13px] font-medium text-white/50 group-hover:text-white/80 transition-colors">
          Read article
          <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
    </div>
  </div>
</a>
