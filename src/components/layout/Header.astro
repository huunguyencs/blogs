---
import { withBase } from '../../utils/url';

const navLinks = [
  { href: '/', label: 'Huu.Ng' },
  { href: withBase('/blog'), label: 'Articles' },
];
---

<header class="sticky top-0 z-50 bg-paper/90 backdrop-blur-xl border-b border-border">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-[72px]">
      <!-- Logo -->
      <a href="/blogs/" class="group flex items-baseline gap-2">
        <span class="font-display text-[28px] text-ink tracking-tight leading-none group-hover:opacity-70 transition-opacity">
          HuuNg. Blog
        </span>
        <span class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-primary-600"></span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 text-[13px] font-medium tracking-wide uppercase text-muted hover:text-ink transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 -mr-2 text-muted hover:text-ink transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="md:hidden hidden border-t border-border bg-paper">
    <div class="px-6 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block py-3 text-[13px] font-medium tracking-wide uppercase text-muted hover:text-ink border-b border-border/50 last:border-0 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
