---
import { withBase } from '../../utils/url';
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-border">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-10 items-end">
      <div>
        <span class="font-display text-4xl text-ink">HuuNg. Blog</span>
        <p class="mt-3 text-sm text-muted max-w-md leading-relaxed">
          Thoughtful writing on technology, development, and the tools that shape how we build.
        </p>
      </div>
      <div class="flex items-center gap-8">
        <a href={withBase("/rss.xml")} class="text-xs font-medium tracking-wide uppercase text-muted hover:text-ink transition-colors">
          RSS
        </a>
        <a href={withBase("/blog")} class="text-xs font-medium tracking-wide uppercase text-muted hover:text-ink transition-colors">
          Archive
        </a>
      </div>
    </div>
    <hr class="editorial-rule my-10" />
    <p class="text-xs text-surface-400">&copy; {year} HuuNg. Blog. All rights reserved.</p>
  </div>
</footer>
