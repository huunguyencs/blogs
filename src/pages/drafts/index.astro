---
import { getCollection } from 'astro:content';
import BlogListLayout from '../../layouts/BlogListLayout.astro';

if (import.meta.env.PROD) {
  return Astro.redirect('/404');
}

const drafts = await getCollection('drafts');
const sorted = drafts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BlogListLayout title="Drafts" description="Draft posts — preview only">
  {sorted.length === 0 ? (
    <p class="text-neutral-500 text-center py-12">No drafts yet.</p>
  ) : (
    <ul class="space-y-4">
      {sorted.map((post) => (
        <li>
          <a href={`${import.meta.env.BASE_URL}drafts/${post.id}`} class="block p-4 rounded-lg border border-neutral-200 dark:border-neutral-700 hover:border-neutral-400 dark:hover:border-neutral-500 transition-colors">
            <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200 mb-2">DRAFT</span>
            <h2 class="text-lg font-semibold">{post.data.title}</h2>
            <p class="text-sm text-neutral-500 mt-1">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</BlogListLayout>
