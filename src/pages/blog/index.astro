---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getPublishedPosts } from '../../utils/posts';

const allPosts = await getPublishedPosts();
---

<BaseLayout
  title="All Articles"
  description="Browse all articles on technology, development, and design."
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-10 lg:py-14">
    <header class="mb-14">
      <h1 class="font-display text-5xl lg:text-6xl text-ink tracking-tight">Articles</h1>
      <p class="mt-3 text-muted text-lg">{allPosts.length} article{allPosts.length !== 1 ? 's' : ''} published</p>
      <hr class="editorial-rule mt-8" />
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {allPosts.map((post, i) => (
        <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms`}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            image={post.data.image}
            slug={post.id}
            rawContent={post.body ?? ''}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
