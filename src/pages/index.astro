---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPost from '../components/blog/HeroPost.astro';
import PostCard from '../components/blog/PostCard.astro';
import PostCardSmall from '../components/blog/PostCardSmall.astro';
import { getPublishedPosts, getCategories, getPostsByCategory } from '../utils/posts';
import { slugify } from '../utils/slugify';
import { getReadingTime } from '../utils/readingTime';
import { formatDate } from '../utils/posts';
import { withBase } from '../utils/url';

const allPosts = await getPublishedPosts();
const featuredPosts = allPosts.filter((p) => p.data.featured);
const latestPosts = allPosts.slice(0, 6);
const categories = getCategories(allPosts);

// Hero: use first featured, or first post
const heroPost = featuredPosts[0] ?? allPosts[0];
// Secondary highlights: next featured posts (or next posts after hero)
const secondaryHighlights = featuredPosts.length > 1
  ? featuredPosts.filter(p => p !== heroPost).slice(0, 2)
  : allPosts.filter(p => p !== heroPost).slice(0, 2);
// Latest: everything not in highlights
const highlightIds = new Set([heroPost?.id, ...secondaryHighlights.map(p => p.id)]);
const latestFiltered = allPosts.filter(p => !highlightIds.has(p.id)).slice(0, 6);
---

<BaseLayout
  title="The Blog"
  description="Thoughtful writing on technology, development, and the tools that shape how we build."
>
  {allPosts.length > 0 ? (
    <>
      <!-- ============================================ -->
      <!-- SECTION 1: HIGHLIGHTS                        -->
      <!-- ============================================ -->
      <section class="max-w-[1400px] mx-auto px-6 lg:px-10 pt-10 lg:pt-14">
        <!-- Section label -->
        <div class="flex items-center gap-4 mb-8">
          <span class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted">Highlights</span>
          <div class="flex-1 h-px bg-border"></div>
        </div>

        <!-- Hero + secondary grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
          <!-- Main hero card -->
          <div class="lg:col-span-8 animate-fade-up">
            <HeroPost
              title={heroPost.data.title}
              description={heroPost.data.description}
              date={heroPost.data.date}
              category={heroPost.data.category}
              image={heroPost.data.image}
              slug={heroPost.id}
              rawContent={heroPost.body ?? ''}
            />
          </div>

          <!-- Secondary highlight cards (stacked) -->
          <div class="lg:col-span-4 flex flex-col gap-6">
            {secondaryHighlights.map((post, i) => (
              <a
                href={withBase(`/blog/${post.id}`)}
                class="group relative isolate flex-1 overflow-hidden rounded-3xl bg-surface-900 animate-fade-up"
                style={`animation-delay: ${(i + 1) * 100}ms`}
              >
                <!-- Gradient base -->
                <div class:list={[
                  'absolute inset-0',
                  i === 0 ? 'bg-gradient-to-br from-primary-800 via-primary-900 to-surface-900' : 'bg-gradient-to-br from-surface-700 via-surface-800 to-surface-900'
                ]} />

                {post.data.image && (
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt}
                    class="absolute inset-0 w-full h-full object-cover opacity-40 transition-all duration-500 group-hover:scale-105 group-hover:opacity-30"
                    loading="eager"
                    onerror="this.style.display='none'"
                  />
                )}

                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" />

                <div class="relative z-10 flex flex-col justify-end h-full min-h-[240px] p-7">
                  <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/50 mb-3">
                    {post.data.category}
                  </span>
                  <h3 class="font-display text-xl lg:text-2xl text-white leading-[1.15] tracking-tight line-clamp-3 group-hover:text-white/80 transition-colors">
                    {post.data.title}
                  </h3>
                  <time datetime={post.data.date.toISOString()} class="mt-3 text-[12px] text-white/35">
                    {formatDate(post.data.date)}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ============================================ -->
      <!-- SECTION 2: LATEST ARTICLES                   -->
      <!-- ============================================ -->
      {latestFiltered.length > 0 && (
        <section class="max-w-[1400px] mx-auto px-6 lg:px-10 pt-20 lg:pt-28">
          <!-- Section header -->
          <div class="flex items-center gap-4 mb-10">
            <span class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted">Latest Articles</span>
            <div class="flex-1 h-px bg-border"></div>
            <a href={withBase("/blog")} class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted hover:text-ink transition-colors">
              View all &rarr;
            </a>
          </div>

          <!-- Articles grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
            {latestFiltered.map((post, i) => (
              <div class="animate-fade-up" style={`animation-delay: ${i * 80}ms`}>
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date}
                  category={post.data.category}
                  image={post.data.image}
                  slug={post.id}
                  rawContent={post.body ?? ''}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- ============================================ -->
      <!-- SECTION 3: TOPICS                            -->
      <!-- ============================================ -->
      {categories.length > 0 && (
        <section class="max-w-[1400px] mx-auto px-6 lg:px-10 pt-20 lg:pt-28">
          <div class="flex items-center gap-4 mb-14">
            <span class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted">Explore Topics</span>
            <div class="flex-1 h-px bg-border"></div>
          </div>

          <div class="space-y-16">
            {categories.map((category) => {
              const categoryPosts = getPostsByCategory(allPosts, category);
              if (categoryPosts.length === 0) return null;

              const topicHero = categoryPosts[0];
              const topicRest = categoryPosts.slice(1, 4);

              return (
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
                  <!-- Topic header + featured card -->
                  <div class="lg:col-span-5">
                    <div class="flex items-center justify-between mb-6">
                      <h2 class="font-display text-3xl text-ink tracking-tight">{category}</h2>
                      <a
                        href={withBase(`/category/${slugify(category)}`)}
                        class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted hover:text-ink transition-colors"
                      >
                        All &rarr;
                      </a>
                    </div>

                    <!-- Topic hero card -->
                    <a href={withBase(`/blog/${topicHero.id}`)} class="group block">
                      <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-gradient-to-br from-surface-100 to-surface-200 mb-4">
                        {topicHero.data.image && (
                          <img
                            src={topicHero.data.image.src}
                            alt={topicHero.data.image.alt}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                            onerror="this.style.display='none'"
                          />
                        )}
                      </div>
                      <h3 class="font-display text-xl text-ink leading-snug tracking-tight group-hover:text-surface-600 transition-colors line-clamp-2">
                        {topicHero.data.title}
                      </h3>
                      <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-2">{topicHero.data.description}</p>
                    </a>
                  </div>

                  <!-- Topic list -->
                  <div class="lg:col-span-7 lg:pt-14">
                    {topicRest.length > 0 ? (
                      <div>
                        {topicRest.map((post) => (
                          <PostCardSmall
                            title={post.data.title}
                            date={post.data.date}
                            category={post.data.category}
                            image={post.data.image}
                            slug={post.id}
                          />
                        ))}
                      </div>
                    ) : (
                      <div class="flex items-center justify-center h-full">
                        <p class="text-sm text-surface-400 italic">More articles coming soon.</p>
                      </div>
                    )}
                  </div>

                  <!-- Divider between topics -->
                  <div class="lg:col-span-12">
                    <hr class="editorial-rule" />
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </>
  ) : (
    <!-- Empty state -->
    <section class="max-w-[1400px] mx-auto px-6 lg:px-10 py-32 text-center">
      <p class="font-display text-4xl text-ink mb-4">Coming soon.</p>
      <p class="text-muted">Articles are on the way. Check back shortly.</p>
    </section>
  )}
</BaseLayout>
