---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getPublishedPosts, getTags, getPostsByTag } from '../../utils/posts';
import { slugify } from '../../utils/slugify';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getTags(posts);
  return tags.map((tag) => ({
    params: { tag: slugify(tag) },
    props: { tag, posts: getPostsByTag(posts, tag) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag}`}
  description={`All articles tagged #${tag}.`}
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-10 lg:py-14">
    <header class="mb-14">
      <a href={withBase("/blog")} class="text-[11px] font-bold tracking-[0.2em] uppercase text-muted hover:text-ink transition-colors mb-4 inline-block">&larr; All Articles</a>
      <h1 class="font-display text-5xl lg:text-6xl text-ink tracking-tight">#{tag}</h1>
      <p class="mt-3 text-muted text-lg">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
      <hr class="editorial-rule mt-8" />
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {posts.map((post, i) => (
        <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms`}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            image={post.data.image}
            slug={post.id}
            rawContent={post.body ?? ''}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
